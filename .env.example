# Copy to `.env` for local development (never commit `.env`).

# FastAPI backend (reservations, payment, auth). No trailing slash.
BACKEND_URL=http://localhost:8000

# Public URL of this SvelteKit app (SEO, sitemap, Open Graph). No trailing slash.
# PUBLIC_SITE_URL=http://localhost:5173

# Optional: custom OG image URL for the home page.
# PUBLIC_OG_IMAGE_URL=

# Optional: HTTP Basic Auth for staging only (not for public production).
# ENABLE_BASIC_AUTH=false
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=
